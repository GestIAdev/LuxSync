{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@stores/*": ["src/stores/*"],
      "@hooks/*": ["src/hooks/*"],
      "@styles/*": ["src/styles/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/main",
    "dist-electron",
    "dist-electron-backend",
    "src/__tests__",
    "src/tests",
    "src/**/disabled",
    "src/**/_legacy_archive",
    "src/**/*.micro-diag.ts",
    "src/**/*.radix2.ts",
    "src/**/*.radix4.ts",
    "src/**/*.recursive-sr.ts",
    "src/**/*.iterative-sr.ts",
    "src/**/*.test.ts"
  ]
}
